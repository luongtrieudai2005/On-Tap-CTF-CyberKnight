<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Danh sách phản hồi</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3>Phản hồi từ nhân viên</h3>
        <a href="/logout" class="btn btn-outline-danger btn-sm">Đăng xuất</a>
      </div>
      <div class="card-body">
        <% if (feedbacks.length === 0) { %>
          <p class="text-muted">Chưa có phản hồi nào.</p>
        <% } else { %>
          <% feedbacks.forEach(function(fb) { %>
            <div class="border rounded p-3 mb-3 bg-white">
              <div class="d-flex justify-content-between mb-2">
                <strong><%= fb.username %></strong>
                <small class="text-muted"><%= fb.created_at %></small>
              </div>
              <div><%- fb.content %></div>
              <hr class="my-2">
              <small class="text-muted">Trạng thái: <%= fb.reviewed ? 'Đã duyệt' : 'Chưa duyệt' %></small>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
