<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Employee Dashboard - The Training Ground</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3>Khu vuc nhan vien</h3>
        <div>
          <span class="badge bg-success me-2"><%= user.role %></span>
          <span class="me-3"><%= user.username %></span>
          <a href="/logout" class="btn btn-outline-danger btn-sm">Dang xuat</a>
        </div>
      </div>
      <div class="card-body">
        <h5>Gui phan hoi cho Ban Giam Doc</h5>
        <p class="text-muted">Nhap y kien dong gop cua ban duoi day:</p>

        <div class="row">
          <div class="col-md-8">
            <div class="mb-3">
              <textarea id="feedbackContent" class="form-control" rows="4" placeholder="Nhap noi dung phan hoi..."></textarea>
            </div>
            <button class="btn btn-primary" onclick="submitFeedback()">Gui phan hoi</button>
            <div id="feedbackMessage" class="mt-2"></div>
          </div>
        </div>

        <hr class="my-4">

        <h5>Lich su phan hoi cua ban</h5>
        <% if (feedbacks.length === 0) { %>
          <p class="text-muted">Chua co phan hoi nao.</p>
        <% } else { %>
          <div class="list-group">
            <% feedbacks.forEach(function(fb) { %>
              <div class="list-group-item">
                <div class="d-flex justify-content-between">
                  <small class="text-muted"><%= fb.created_at %></small>
                  <% if (fb.reviewed) { %>
                    <span class="badge bg-success">Da xem</span>
                  <% } else { %>
                    <span class="badge bg-warning text-dark">Chua xem</span>
                  <% } %>
                </div>
                <p class="mb-1 mt-1"><%= fb.content %></p>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    function submitFeedback() {
      const content = document.getElementById('feedbackContent').value
      if (!content) {
        document.getElementById('feedbackMessage').innerHTML = '<div class="alert alert-warning">Vui long nhap noi dung.</div>'
        return
      }

      fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content })
      })
      .then(r => r.json())
      .then(data => {
        const msg = document.getElementById('feedbackMessage')
        if (data.success) {
          msg.innerHTML = '<div class="alert alert-success">Phan hoi da duoc gui!</div>'
          document.getElementById('feedbackContent').value = ''
          setTimeout(() => location.reload(), 1000)
        } else {
          msg.innerHTML = '<div class="alert alert-danger">' + data.error + '</div>'
        }
      })
    }
  </script>
</body>
</html>
